{
  "manifest_version": 3,
  "name": "AI Privacy Guard",
  "version": "0.2.0",
  "description": "Paste text → ตรวจ sensitive data → Copy ที่ปลอดภัย",

  "permissions": ["storage", "clipboardWrite"],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "AI Privacy Guard"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
